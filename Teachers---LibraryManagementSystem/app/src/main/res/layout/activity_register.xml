<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/back1"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" >

            <TextView
                android:id="@+id/home_userid"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="#000000"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="italic" />

            <EditText
                android:id="@+id/registernamefield"
                android:layout_width="300dp"
                android:layout_height="40dp"

                android:layout_marginTop="68dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Enter Name:"
                android:inputType="textPersonName"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/registerpasswordfield1"
                android:layout_width="300dp"
                android:layout_height="40dp"
                android:layout_marginTop="40dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Enter Password:"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/registerpasswordfield2"
                android:layout_width="300dp"
                android:layout_height="40dp"
                android:layout_marginTop="40dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Confirm Password:"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/registerenrollmentnofield"
                android:layout_width="300dp"
                android:layout_height="40dp"
                android:layout_marginTop="40dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Enter Enrollment No:"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/registercoursefield"
                android:layout_width="300dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:background="#FFFFFF"
                android:ems="10"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Enter Course:"
                android:inputType="textPersonName" />

            <EditText
                android:id="@+id/registeremailfield"
                android:layout_width="300dp"
                android:layout_height="40dp"
                android:layout_marginTop="40dp"
                android:autofillHints=""
                android:background="#FFFFFF"
                android:ems="10"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hint="Enter Email:"
                android:inputType="textEmailAddress" />

            <Button
                android:id="@+id/signupbutton"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="36dp"
                android:background="#FFFFFF"
                android:clickable="true"
                android:foreground="@drawable/ripple_effect"
                android:foregroundGravity="center"
                android:gravity="center"
                android:hapticFeedbackEnabled="true"
                android:text="Sign up"
                android:textColor="#000000"
                app:backgroundTint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="100dp"
                android:layout_marginBottom="16dp"
                android:background="#FF0000"
                android:foregroundGravity="center"
                android:gravity="center"
                android:text="All Fields Are Case-Sensitive!"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>